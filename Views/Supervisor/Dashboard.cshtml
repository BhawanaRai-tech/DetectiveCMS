@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Supervisor Control | Shadow Files</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #0a0f1c;
            color: white;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            background: #111827;
            padding-top: 20px;
            box-shadow: 2px 0 15px rgba(0,150,255,0.3);
        }

        .sidebar h2 {
            text-align: center;
            color: #00aaff;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            padding: 12px 20px;
            color: #ccc;
            text-decoration: none;
            font-size: 14px;
        }

        .sidebar a:hover {
            background: #1e293b;
            color: #00aaff;
        }

        .main {
            margin-left: 240px;
            padding: 30px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }

        .logout{
            padding:20px;
            margin-top: 210px;
        }

        .logout a{
            background:#ff2e4d;
            display:block;
            text-align:center;
            padding:10px;
            border-radius:6px;
            color:white;
        }

        .logout a:hover{
            background:#ff4d6a;
        }


        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: #1e293b;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,150,255,0.2);
        }

        .card h3 {
            margin: 0;
            color: #00aaff;
        }

        .case-table {
            width: 100%;
            border-collapse: collapse;
            background: #1e293b;
            border-radius: 8px;
            overflow: hidden;
        }

        .case-table th, .case-table td {
            padding: 12px;
            text-align: left;
            font-size: 14px;
        }

        .case-table th {
            background: #111827;
            color: #00aaff;
        }

        .case-table tr {
            border-bottom: 1px solid #2c3e50;
        }

        .approve-btn {
            background: #00ffaa;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            margin-right: 5px;
        }

        .reject-btn {
            background: #ff4d4d;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
        }
    </style>
</head>
<body>

<div class="sidebar">
<div class="sidebar-top">
    <h2>SUPERVISOR</h2>

    <a href="#"><i class="fa fa-folder-open"></i> Active Cases</a>
    <a href="#"><i class="fa fa-file-alt"></i> Review Reports</a>
    <a href="#"><i class="fa fa-chart-line"></i> Statistics</a>
    <a href="#"><i class="fa fa-user-check"></i> Detective Activity</a>
</div>

<div class="logout">
    <a href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> Logout</a>
</div>
</div>
<div class="main">
    <div class="stats">
        <div class="card">
            <h3>Total Active Cases</h3>
            <h2>9</h2>
        </div>

        <div class="card">
            <h3>Pending Reports</h3>
            <h2>4</h2>
        </div>

        <div class="card">
            <h3>Closed This Month</h3>
            <h2>6</h2>
        </div>
    </div>

    <h2>Cases Awaiting Approval</h2>

    <table class="case-table">
        <tr>
            <th>Case ID</th>
            <th>Title</th>
            <th>Assigned Detective</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </table>
</div>
</body>
</html>