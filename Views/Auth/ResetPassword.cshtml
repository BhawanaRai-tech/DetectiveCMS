@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Shadow Files | Reset Password</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            background: url('/images/Detective.png') no-repeat center center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        body::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.45);
            z-index: 0;
        }

        .card {
            position: relative;
            z-index: 1;
            width: 400px;
            padding: 35px;
            border-radius: 12px;
            background: rgba(0, 0, 0, 0.85);
            box-shadow: 0 0 25px rgba(255, 0, 0, 0.3);
            color: white;
        }

        .card h2 {
            text-align: center;
            color: #ff2e4d;
            margin-bottom: 25px;
        }

        .input-group {
            position: relative;
            margin-bottom: 18px;
        }

        .input-group input,
        .input-group select {
            width: 100%;
            height: 42px;
            padding: 0 40px 0 40px;
            border-radius: 6px;
            border: none;
            outline: none;
            background: #1c1c1c;
            color: white;
            box-sizing: border-box;
        }

        .left-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
        }

        .btn {
            width: 100%;
            height: 42px;
            border: none;
            border-radius: 6px;
            background: #ff2e4d;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        .btn:hover {
            background: #ff4d6a;
        }

        .error {
            color: yellow;
            text-align: center;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

<div class="card">
    <h2>RESET PASSWORD</h2>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

    <form method="post">

        <div class="input-group">
            <i class="fa fa-lock left-icon"></i>
            <input type="password" name="newPassword" placeholder="New Password" required />
        </div>

        <div class="input-group">
            <i class="fa fa-lock left-icon"></i>
            <input type="password" name="confirmPassword" placeholder="Confirm Password" required />
        </div>

        <button type="submit" class="btn">UPDATE PASSWORD</button>
        <div class="links">
            <a asp-action="Login">Back to Login</a>
        </div>

    </form>
</div>

</body>
</html>