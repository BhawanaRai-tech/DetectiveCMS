@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Shadow Files | Password Recovery</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            background: url('/images/Detective.png') no-repeat center center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        body::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.45);
            z-index: 0;
        }

        .forgot-card {
            position: relative;
            z-index: 1;
            width: 400px;
            padding: 35px;
            border-radius: 12px;
            background: rgba(0, 0, 0, 0.88);
            box-shadow: 0 0 25px rgba(255, 0, 0, 0.3);
            color: white;
        }

        .forgot-card h2 {
            text-align: center;
            margin-bottom: 8px;
            letter-spacing: 2px;
            color: #ff2e4d;
        }

        .subtitle {
            text-align: center;
            font-size: 13px;
            margin-bottom: 25px;
            color: #ccc;
        }

        .input-group {
            position: relative;
            margin-bottom: 18px;
        }

        .input-group input,
        .input-group select {
            width: 100%;
            height: 42px;
            padding: 0 40px 0 40px;
            border-radius: 6px;
            border: none;
            outline: none;
            background: #1c1c1c;
            color: white;
            box-sizing: border-box;
        }

        .left-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
        }

        .btn-reset {
            width: 100%;
            height: 42px;
            border: none;
            border-radius: 6px;
            background: #ff2e4d;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        .btn-reset:hover {
            background: #ff4d6a;
        }

        .links {
            text-align: center;
            margin-top: 18px;
            font-size: 13px;
        }

        .links a {
            color: #ccc;
            text-decoration: none;
        }

        .links a:hover {
            color: #ff2e4d;
        }
    </style>
</head>
<body>

<div class="forgot-card">

    <h2>PASSWORD RECOVERY</h2>
    <div class="subtitle">
        Enter your registered email and agent code to reset password.
    </div>

    <form method="post">

        <div class="input-group">
            <i class="fa fa-envelope left-icon"></i>
            <input type="email" placeholder="Registered Email" required />
        </div>

        <div class="input-group">
            <i class="fa fa-key left-icon"></i>
            <input type="text" placeholder="Agent Code" required />
        </div>

        <button type="submit" class="btn-reset">
            SEND RESET REQUEST
        </button>

        <div class="links">
            Remember your password?
            <a asp-action="Login">Back to Login</a>
        </div>

    </form>

</div>

</body>
</html>