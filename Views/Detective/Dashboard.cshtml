@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Detective Terminal | Shadow Files</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #0b0b0b;
            color: white;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            background: #141414;
            padding-top: 20px;
            box-shadow: 2px 0 15px rgba(0,255,150,0.2);
        }

        .sidebar h2{
            text-align:center;
            color:#ff2e4d;
            margin-bottom:30px;
        }

        .sidebar a {
            display: block;
            padding: 12px 20px;
            color: #ccc;
            text-decoration: none;
            font-size: 14px;
        }

        .sidebar a:hover {
            background: #1f1f1f;
            color: #00ffaa;
        }

        .main {
            margin-left: 240px;
            padding: 30px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
        }

        .logout{
            padding:20px;
            margin-top: 210px;
        }

        .logout a{
            background:#ff2e4d;
            display:block;
            text-align:center;
            padding:10px;
            border-radius:6px;
            color:white;
        }

        .logout a:hover{
            background:#ff4d6a;
        }
        
        .case-table {
            width: 100%;
            border-collapse: collapse;
            background: #1a1a1a;
            border-radius: 8px;
            overflow: hidden;
        }

        .case-table th, .case-table td {
            padding: 12px;
            text-align: left;
            font-size: 14px;
        }

        .case-table th {
            background: #111;
            color: #00ffaa;
        }

        .case-table tr {
            border-bottom: 1px solid #333;
        }

        .status-open {
            color: #ffcc00;
        }

        .status-closed {
            color: #00ffaa;
        }

        .action-btn {
            background: #00ffaa;
            border: none;
            padding: 5px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
        }

        .action-btn:hover {
            background: #00cc88;
        }
    </style>
</head>
<body>

<div class="sidebar">
<div class="sidebar-top">
    <h2>DETECTIVE</h2>

    <a href="#"><i class="fa fa-folder"></i> Assigned Cases</a>
    <a href="#"><i class="fa fa-file-alt"></i> Submit Report</a>
    <a href="#"><i class="fa fa-upload"></i> Upload Evidence</a>
    <a href="#"><i class="fa fa-user"></i> Profile</a>
</div>
    <div class="logout">
        <a href="/Auth/Logout"><i class="fa fa-sign-out-alt"></i> Logout</a>
    </div>
</div>


<div class="main">

   

    <h2>My Assigned Cases</h2>

    <table class="case-table">
        <tr>
            <th>Case ID</th>
            <th>Title</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Action</th>
        </tr>

    </table>

</div>

</body>
</html>