@model ShadowFile.Models.User

@{
Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <title>Edit Agent | Shadow Files</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>

    <style>

        body{
            margin:0;
            padding:0;
            font-family:'Segoe UI',sans-serif;
            height:100vh;
            background:url('/images/Detective.png') no-repeat center center/cover;
            display:flex;
            justify-content:center;
            align-items:center;
        }

        /* overlay */
        body::before{
            content:"";
            position:absolute;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.45);
            z-index:0;
        }

        .form-card{
            position:relative;
            z-index:1;
            width:400px;
            padding:35px;
            border-radius:12px;
            background:rgba(0,0,0,0.85);
            box-shadow:0 0 25px rgba(255,0,0,0.3);
            color:white;
        }

        .form-card h2{
            text-align:center;
            margin-bottom:5px;
            letter-spacing:2px;
            color:#ff2e4d;
        }

        .subtitle{
            text-align:center;
            font-size:13px;
            margin-bottom:25px;
            color:#ccc;
        }

        .input-group{
            position:relative;
            margin-bottom:18px;
        }

        .input-group input,
        .input-group select{
            width:100%;
            height:42px;
            padding:0 40px;
            border-radius:6px;
            border:none;
            outline:none;
            background:#1c1c1c;
            color:white;
            box-sizing:border-box;
        }

        .left-icon{
            position:absolute;
            left:12px;
            top:50%;
            transform:translateY(-50%);
            color:#aaa;
        }

        .btn-update{
            width:100%;
            height:42px;
            border:none;
            border-radius:6px;
            background:#ff2e4d;
            color:white;
            font-weight:bold;
            cursor:pointer;
        }

        .btn-update:hover{
            background:#ff4d6a;
        }

        .exit{
            margin-top:18px;
            text-align:center;
        }

        .exit a{
            color:#ccc;
            text-decoration:none;
        }

        .exit a:hover{
            color:#ff2e4d;
        }

    </style>

</head>

<body>

<div class="form-card">

    <h2>EDIT AGENT</h2>
    <div class="subtitle">Modify Investigation Member</div>

    <form method="post">

        <input type="hidden" name="Id" value="@Model.Id"/>

        <div class="input-group">
            <i class="fa fa-user left-icon"></i>
            <input type="text" name="Username" value="@Model.Username" required/>
        </div>

        <div class="input-group">
            <i class="fa fa-key left-icon"></i>
            <input type="text" name="AgentCode" value="@Model.AgentCode" required/>
        </div>

        <div class="input-group">
            <i class="fa fa-user-check left-icon"></i>

            <select name="IsActive">

                @if (Model.IsActive)
                {
                    <option value="true" selected>Active</option>
                    <option value="false">Inactive</option>
                }
                else
                {
                    <option value="true">Active</option>
                    <option value="false" selected>Inactive</option>
                }

            </select>

        </div>
        <button type="submit" class="btn-update">
            <i class="fa fa-save"></i> Update Agent
        </button>

    </form>
    <div class="exit">
        <a href="/Admin/ManageAgents">
            <i class="fa fa-arrow-left"></i> Exit to Manage Agents
        </a>
    </div>

</div>

</body>
</html>