@model IEnumerable<ShadowFile.Models.User>

@{
Layout = null;
}

<!DOCTYPE html>
<html>
<head>

<title>Manage Agents | Shadow Files</title>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
    background:url('/images/Detective.png') no-repeat center center/cover;
color:white;
}

/* MAIN */

.container{
padding:40px;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.header h1{
color:white;
}

/* BUTTONS */

.btn{
padding:10px 18px;
border:none;
border-radius:6px;
cursor:pointer;
font-size:14px;
text-decoration:none;
}

.btn-add{
background:#ff2e4d;
color:white;
}

.btn-add:hover{
background:#ff4d6a;
}

.btn-exit{
background:#333;
color:white;
margin-right:10px;
}

.btn-exit:hover{
background:#444;
}

/* TABLE */

.table-container{
background:#161616;
padding:20px;
border-radius:10px;
box-shadow:0 0 15px rgba(255,0,0,0.15);
}

table{
width:100%;
border-collapse:collapse;
}

th{
text-align:left;
padding:12px;
color:#ff2e4d;
border-bottom:1px solid #333;
}

td{
padding:12px;
border-bottom:1px solid #222;
color:#ccc;
}

/* ACTION BUTTONS */

.action-btn{
padding:6px 12px;
border-radius:4px;
font-size:12px;
text-decoration:none;
margin-right:5px;
}

.view{
background:#2196f3;
color:white;
}

.edit{
background:#ff9800;
color:white;
}

.delete{
background:#f44336;
color:white;
}

</style>

</head>

<body>

<div class="container">

    <div class="header">

        <h1>Manage Agents</h1>

        <div>

            <a href="/Admin/Dashboard" class="btn btn-exit">
                <i class="fa fa-arrow-left"></i> Exit
            </a>

            <a href="/Admin/CreateAgent" class="btn btn-add">
                <i class="fa fa-user-plus"></i> Add Agent
            </a>

        </div>

    </div>

    <div class="table-container">

        <table>

            <tr>
                <th>Username</th>
                <th>Agent Code</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>

            @foreach(var agent in Model)
            {
                <tr>

                    <td>@agent.Username</td>

                    <td>@agent.AgentCode</td>

                    <td>@(agent.Role != null ? agent.Role.RoleName : "No Role")</td>

                    <td>@(agent.IsActive ? "Active" : "Inactive")</td>

                    <td>

                        <a class="action-btn view" href="/Admin/AgentDetails/@agent.Id">View</a>

                        <a class="action-btn edit" href="/Admin/EditAgent/@agent.Id">Edit</a>

                        <a class="action-btn delete"
                           href="/Admin/DeleteAgent/@agent.Id"
                           onclick="return confirmDelete()">
                            <i class="fa fa-trash"></i> Delete
                        </a>

                    </td>

                </tr>
            }

        </table>

    </div>

</div>
<script>
function confirmDelete() {

    return confirm("⚠ Are you sure you want to delete this agent?\n\nThis action cannot be undone.");

}
</script>
</body>
</html>